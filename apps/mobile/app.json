{
  "expo": {
    "name": "Vectra",
    "slug": "vectra",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vectra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vectra.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Vectra uses your microphone for cold call training.",
        "NSFaceIDUsageDescription": "Vectra uses Face ID to secure your account.",
        "NSContactsUsageDescription": "Vectra can import contacts to create leads."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.vectra.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#09090b"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Vectra uses Face ID to secure your account."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Vectra uses your microphone for cold call training."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
