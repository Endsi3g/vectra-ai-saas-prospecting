# =============================================================================
# Vectra OS — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required — https://app.supabase.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# -----------------------------------------------------------------------------
# STRIPE BILLING (Required for payments — https://dashboard.stripe.com)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...        # Monthly Starter plan price ID
STRIPE_PRICE_AGENCY=price_...      # Monthly Scale plan price ID

# -----------------------------------------------------------------------------
# NYLAS V3 — Email OAuth (Required for inbox — https://dashboard.nylas.com)
# -----------------------------------------------------------------------------
NYLAS_CLIENT_ID=d12165a7-6c3b-4efc-a754-e9fdb60833fe
NYLAS_CLIENT_SECRET=nyk_v0_...
NYLAS_REDIRECT_URI=https://yourdomain.com/api/auth/nylas/callback
# For local dev: NYLAS_REDIRECT_URI=http://localhost:3000/api/auth/nylas/callback

# -----------------------------------------------------------------------------
# AI / LLM (At least one required for real message generation)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...   # Preferred — free models available
# OPENAI_API_KEY=sk-...           # Alternative — uses gpt-4o-mini

# -----------------------------------------------------------------------------
# SERPER.DEV — Google Search for Sourcing (Optional, mock fallback available)
# Get your key at https://serper.dev
# -----------------------------------------------------------------------------
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# RESEND — Transactional Email (Optional — https://resend.com)
# Used for welcome emails and password resets
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# POSTHOG — Product Analytics (Optional — https://posthog.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# SENTRY — Error Monitoring (Optional — https://sentry.io)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# -----------------------------------------------------------------------------
# SITE URL (for invite redirects and OAuth callbacks)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# For local dev: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# TESTING (Development only)
# -----------------------------------------------------------------------------
# PLAYWRIGHT_TEST=false
